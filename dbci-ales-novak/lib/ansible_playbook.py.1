#!/usr/bin/env python2

import os
import yaml

from collections import namedtuple

import ansible.release

from ansible.executor.task_queue_manager import TaskQueueManager
if ansible.release.__version__ < '2.4':
    from ansible.inventory import Inventory
else:
    from ansible.inventory.manager import InventoryManager
from ansible.parsing.dataloader import DataLoader
from ansible.playbook.play import Play
from ansible.plugins.callback import CallbackBase
if ansible.release.__version__ < '2.4':
    from ansible.vars import VariableManager
else:
    from ansible.vars.manager import VariableManager
from ansible.parsing.splitter import parse_kv

# Create a callback object so we can capture the output
class ResultsCollector(CallbackBase):

    def __init__(self, *args, **kwargs):
        super(ResultsCollector, self).__init__(*args, **kwargs)
        self.host_ok = {}
        self.host_unreachable = {}
        self.host_failed = {}

    def v2_runner_on_unreachable(self, result):
        self.host_unreachable[result._host.get_name()] = result

    def v2_runner_on_ok(self, result, *args, **kwargs):
        self.host_ok[result._host.get_name()] = result

    def v2_runner_on_failed(self, result, *args, **kwargs):
        self.host_failed[result._host.get_name()] = result

def print_result(host, result, status):
    print("-" * 78)
    print("{0}: {1}".format(host, status))
    if "cmd" in result:
        print("Executed: "),
        if isinstance(result["cmd"], list) or isinstance(result["cmd"], tuple):
            print("{0}".format(" ".join(result["cmd"])))
        elif isinstance(result["cmd"], basestring):
            print("{0}".format(result["cmd"]))
        else:
            print("{0}".format(result))
    if "start" in result:
        print("Started at: {0}".format(result["start"]))
    if "end" in result:
        print("Finished at: {0}".format(result["end"]))
    if "delta" in result:
        print("Took: {0}".format(result["delta"]))
    if "stdout" in result:
        print("Stdout:")
        if result["stdout"] != '':
            print("{0}".format(result["stdout"]))
    if "stderr" in result:
        print("Stderr:")
        if result["stderr"] != '':
            print("{0}".format(result["stderr"]))

def ansible_playbook(playbook_path, inventory_sources=None, extra_vars=None):

    if os.sep not in playbook_path:
        playbook_path = os.path.join(os.sep, "dba", "local", "ansible", playbook_path)

    if inventory_sources is None:
        i = os.path.join(os.path.dirname(playbook_path), "inventory", "hosts")
        if os.path.exists(i) and os.path.isfile(i):
            inventory_sources = [i]

    Options = namedtuple("Options", [
        "connection",
        "forks",
        "module_path",
        "become",
        "become_method",
        "become_user",
        "check",
        "diff",
        "log_path",
    ])

    # initialize needed objects
    loader = DataLoader()
    options = Options(
        connection="ssh",
        forks=8,
        module_path=None,
        become=None,
        become_method=None,
        become_user=None,
        check=False,
        diff=False,
        log_path="/var/log/dba/dbci.log",
    )

    passwords = dict()

    # create inventory and pass to var manager
    if ansible.release.__version__ < '2.4':
        variable_manager = VariableManager()
        # dirty hack for ansible 2.3
        if inventory_sources is None:
            host_list = None
        elif isinstance(inventory_sources, list) or isinstance(inventory_sources, tuple):
            host_list = inventory_sources[0]
        else:
            raise ValueError(str(type(inventory_sources)) + ' is not support')
        inventory = Inventory(loader=loader, variable_manager=variable_manager, host_list=inventory_sources[0])
        variable_manager.set_inventory(inventory)
    else:
        inventory = Inventory(loader=loader, sources=inventory_sources)
        variable_manager = VariableManager(loader=loader, inventory=inventory)

    variable_manager.extra_vars = extra_vars

    # load playbook
    os.chdir(os.path.dirname(playbook_path))
    playbooks = yaml.load(open(os.path.basename(playbook_path)))
    for playbook in playbooks:
        play = Play().load(playbook, variable_manager=variable_manager, loader=loader)

        # actually run it
        tqm = None
        callback = ResultsCollector()
        try:
            tqm = TaskQueueManager(
                inventory=inventory,
                variable_manager=variable_manager,
                loader=loader,
                options=options,
                passwords=passwords,
            )
            tqm._stdout_callback = callback
            result = tqm.run(play)
        finally:
            if tqm is not None:
                tqm.cleanup()

        for host, result in callback.host_failed.items():
            print_result(host, result._result, "FAILED")

        for host, result in callback.host_unreachable.items():
            print_result(host, result._result, "UNREACHABLE")

        for host, result in callback.host_ok.items():
            print_result(host, result._result, "SUCCESS")


if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(description="Run an Ansible playbook in the CSAS environment")
    parser.add_argument("-i", "--inventory",  help="an Ansible inventory filename")
    parser.add_argument("-e", "--extra_vars", help="variables e.g. server=localhost db=ORACLE")
    parser.add_argument("playbook", help="an Ansible playbook filename")
    args = parser.parse_args()

    ansible_playbook(args.playbook, args.inventory, parse_kv(args.extra_vars))
