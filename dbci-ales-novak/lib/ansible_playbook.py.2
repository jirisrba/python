global_return_code = 0

def dump(obj):
    print("-" * 78)
    for attr in dir(obj):
        print("obj.%s = %r" % (attr, getattr(obj, attr)))

def result_print(state, result):
    global global_return_code
    if state == "FAILED":
        if result._task_fields["ignore_errors"]:
            state = "IGNORED"
        else:
            global_return_code = 1
    print("-" * 78)
    print("state: {} host: {} task: {}".format(
        state,
        result._host.get_name(),
        result.task_name,
    ))
    if "cmd" in result._result:
        if isinstance(result._result["cmd"], basestring):
            print("cmd: {}".format(result._result["cmd"]))
        elif isinstance(result._result["cmd"], tuple) or isinstance(result._result["cmd"], list):
            print("cmd: {}".format(" ".join(result._result["cmd"])))
        else:
            print("cmd: {}".format(result._result["cmd"]))
    if "start" in result._result and "end" in result._result and "delta" in result._result:
      print("start:{} end:{}, taken:{}".format(
          result._result["start"],
          result._result["end"],
          result._result["delta"],
      ))
    if "taskdir" in result._result:
        print("taskdir: {}".format(result._result["taskdir"]))
    if "rc" in result._result:
        print("rc: {}".format(result._result["rc"]))
    if "stdout" in result._result:
        print("stdout:")
        if len(result._result["stdout"]) != 0:
            print(result._result["stdout"])
    if "stderr" in result._result:
        print("stderr:")
        if len(result._result["stderr"]) != 0:
            print(result._result["stderr"])
    if "results" in result._result:
        print("items:")
        for r in result._result["results"]:
            print("- {}".format(r["item"]))
    print

class ResultsCollector(CallbackBase):
    def __init__(self, *args, **kwargs):
        super(ResultsCollector, self).__init__(*args, **kwargs)

    def v2_runner_on_unreachable(self, result, ignore_errors=False):
        name = result._host.get_name()
        task = result._task.get_name()
        print("state: UNREACHABLE host: {} task: {}".format(name, task))

    def v2_runner_on_ok(self, result,  *args, **kwargs):
        name = result._host.get_name()
        task = result._task.get_name()
        if "DBCI" in task: result_print("OK", result)
        #if "remove the dump files" in task: dump(result)

    def v2_runner_on_failed(self, result,   *args, **kwargs):
        name = result._host.get_name()
        task = result._task.get_name()
        result_print("FAILED", result)

